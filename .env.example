# Database Configuration
# Local:
# DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/ArenasApp
#
# Railway (PostgreSQL service → Connect):
# Use the PUBLIC / external URL (host like kodama.proxy.rlwy.net:PORT).
# Do NOT use postgres.railway.internal — that only works inside Railway, not from Render.
# DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway
DATABASE_URL=postgresql://user:password@localhost:5432/arenas360

# JWT Settings — use a random string of at least 32 characters in production
SECRET_KEY=your-super-secret-key-change-in-production

# CORS (comma-separated origins; use * only for local dev without credentials)
# CORS_ORIGINS=https://your-app.example.com,exp://192.168.1.10:8081

# Server Settings
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Expo client settings (use your LAN IP so the phone can reach the API)
EXPO_PUBLIC_API_URL=https://arenas360-x00o.onrender.com
API_PUBLIC_URL=https://arenas360-x00o.onrender.com

# Event images from DB (`eventos.foto` relative paths)
# Option A: Google Cloud Storage (same bucket as the web platform)
GCS_BUCKET=arenas360-media
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json

# Option B: Public CDN URL (if files are publicly accessible)
# MEDIA_BASE_URL=https://storage.googleapis.com/arenas360-media

# Option C: Local folder mirroring paths like eventos/public/xxx.png
# MEDIA_ROOT=media

# Push notifications (Expo): run `npx eas init` and add to app.json extra.eas.projectId
# Push works on physical device; use EAS Build for production iOS/Android.

# Render deployment (backend web service)
# After deploy, set in Render dashboard:
#   DATABASE_URL=<Railway PostgreSQL URL>
#   API_PUBLIC_URL=https://arenas360-api.onrender.com
# Then update EXPO_PUBLIC_API_URL in eas.json / .env to the same Render URL.
# Example production URL:
# EXPO_PUBLIC_API_URL=https://arenas360-api.onrender.com
