{
  "expo": {
    "name": "arenas360",
    "slug": "arenas360",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/android-icon-foreground.png",
    "scheme": "arenas360",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "navigationBarColor": "#001529",
      "statusBar": {
        "backgroundColor": "#061629",
        "barStyle": "light-content",
        "translucent": false
      },
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.josechaverra9010.arenas360"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#001529",
          "android": {
            "image": "./assets/images/icon.png",
            "imageWidth": 120
          },
          "ios": {
            "image": "./assets/images/icon.png",
            "imageWidth": 120
          }
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#FF9F1C",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite a Arenas 360 acceder a tus fotos para actualizar tu foto de perfil."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "newArchEnabled": true
          },
          "ios": {
            "newArchEnabled": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "521be345-ae06-4915-b3ab-9d9ffcb0c599"
      }
    }
  }
}
